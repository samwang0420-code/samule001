---
export interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}

const { 
  title, 
  description = "GEO-powered local search optimization for Houston immigration lawyers. Millimeter-level precision coordinates, dynamic Schema markup, real-time competitor monitoring.",
  ogImage = "/geo-og.jpg"
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <meta name="generator" content={Astro.generator} />
  
  <!-- Primary Meta Tags -->
  <title>{title}</title>
  <meta name="title" content={title} />
  <meta name="description" content={description} />
  <link rel="canonical" href={canonicalURL} />
  
  <!-- Open Graph / Facebook -->
  <meta property="og:type" content="website" />
  <meta property="og:url" content={canonicalURL} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={ogImage} />
  
  <!-- Twitter -->
  <meta property="twitter:card" content="summary_large_image" />
  <meta property="twitter:url" content={canonicalURL} />
  <meta property="twitter:title" content={title} />
  <meta property="twitter:description" content={description} />
  <meta property="twitter:image" content={ogImage} />
  
  <!-- Tailwind CSS -->
  <script src="https://cdn.tailwindcss.com"></script>
  
  <!-- Schema.org Organization -->
  <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "Organization",
      "name": "StackMatrices GEO",
      "url": "https://stackmatrices.com/geo",
      "logo": "https://stackmatrices.com/logo.png",
      "sameAs": [
        "https://twitter.com/stackmatrices"
      ],
      "contactPoint": {
        "@type": "ContactPoint",
        "email": "geo@stackmatrices.com",
        "contactType": "sales"
      }
    }
  </script>
</head>
<body class="bg-white text-slate-900 min-h-screen flex flex-col">
  <slot name="header">
    <Header />
  </slot>
  <main class="flex-1">
    <slot />
  </main>
  
  <footer class="bg-slate-50 border-t border-slate-200 py-8">
    <div class="max-w-7xl mx-auto px-4">
      <div class="flex flex-col md:flex-row justify-between items-center gap-4">
        <div class="text-sm text-slate-500">
          © 2024 StackMatrices. GEO Marketing for Immigration Lawyers.
        </div>
        <div class="flex gap-6 text-sm">
          <a href="./" class="text-slate-500 hover:text-blue-600">GEO Home</a>
          <a href="./audit" class="text-slate-500 hover:text-blue-600">Free Audit</a>
          <a href="./pricing" class="text-slate-500 hover:text-blue-600">Pricing</a>
        </div>
      </div>
    </div>
  </footer>
</body>
</html>
