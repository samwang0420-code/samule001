---
import Layout from '../layouts/Layout.astro';
---

<Layout title="GEO Marketing for Immigration Lawyers | StackMatrices">
  <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    
    <!-- Breadcrumb -->
    <nav class="text-sm text-slate-500 mb-8">
      <a href="/" class="hover:text-blue-600">Home</a>
      <span class="mx-2">/</span>
      <span>GEO</span>
    </nav>

    <!-- Hero -->
    <section class="text-center mb-20">
      <div class="inline-block bg-blue-100 text-blue-800 px-4 py-2 rounded-full text-sm font-semibold mb-6">
        🎯 New: Houston Immigration Lawyer GEO System
      </div>
      
      <h1 class="text-5xl font-bold text-slate-900 mb-6">
        Millimeter-Level Local Search Optimization
      </h1>
      
      <p class="text-xl text-slate-600 mb-8 max-w-2xl mx-auto">
        GEO-powered ranking system for Houston immigration lawyers. 
        Precision coordinates. Dynamic Schema. Real-time competitor monitoring.
      </p>
      
      <div class="flex justify-center gap-4 flex-wrap">
        <a href="./audit" 
           class="bg-blue-600 text-white px-8 py-3 rounded-lg font-semibold hover:bg-blue-700">
          Check Your GEO Score →
        </a>
        <a href="./houston/immigration" 
           class="border-2 border-slate-300 text-slate-700 px-8 py-3 rounded-lg font-semibold hover:border-blue-600 hover:text-blue-600">
          Houston Market Report
        </a>
      </div>
    </section>

    <!-- Stats -->
    <section class="grid md:grid-cols-3 gap-8 mb-20">
      <div class="bg-slate-50 p-8 rounded-2xl text-center">
        <div class="text-4xl font-bold text-blue-600 mb-2">127</div>
        <div class="text-slate-600">Houston Immigration Lawyers Analyzed</div>
      </div>
      <div class="bg-slate-50 p-8 rounded-2xl text-center">
        <div class="text-4xl font-bold text-blue-600 mb-2">#3</div>
        <div class="text-slate-600">Average Ranking Improvement</div>
      </div>
      <div class="bg-slate-50 p-8 rounded-2xl text-center">
        <div class="text-4xl font-bold text-blue-600 mb-2">15m</div>
        <div class="text-slate-600">Coordinate Precision</div>
      </div>
    </section>

    <!-- How It Works -->
    <section class="mb-20">
      <h2 class="text-3xl font-bold text-center mb-12">How GEO Works</h2>
      
      <div class="grid md:grid-cols-4 gap-6">
        <div class="text-center">
          <div class="w-16 h-16 bg-blue-100 rounded-full flex items-center justify-center mx-auto mb-4 text-2xl">📍</div>
          <h3 class="font-semibold mb-2">1. Precision Mapping</h3>
          <p class="text-sm text-slate-600">Map to building entrance, not street. Capture elevation data.</p>
        </div>
        
        <div class="text-center">
          <div class="w-16 h-16 bg-blue-100 rounded-full flex items-center justify-center mx-auto mb-4 text-2xl">🅿️</div>
          <h3 class="font-semibold mb-2">2. Context Injection</h3>
          <p class="text-sm text-slate-600">Add parking, transit, nearby landmarks to knowledge graph.</p>
        </div>
        
        <div class="text-center">
          <div class="w-16 h-16 bg-blue-100 rounded-full flex items-center justify-center mx-auto mb-4 text-2xl">⚡</div>
          <h3 class="font-semibold mb-2">3. Dynamic Schema</h3>
          <p class="text-sm text-slate-600">Real-time updated Schema.org markup. Always fresh.</p>
        </div>
        
        <div class="text-center">
          <div class="w-16 h-16 bg-blue-100 rounded-full flex items-center justify-center mx-auto mb-4 text-2xl">📊</div>
          <h3 class="font-semibold mb-2">4. Monitor & Adapt</h3>
          <p class="text-sm text-slate-600">Track rankings vs competitors. Auto-adjust strategy.</p>
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="bg-slate-900 text-white rounded-2xl p-12 text-center">
      <h2 class="text-3xl font-bold mb-4">Ready to Dominate Local Search?</h2>
      <p class="text-slate-400 mb-8 max-w-xl mx-auto">
        Get your free GEO score. See how you rank vs 127 other Houston immigration lawyers.
      </p>
      
      <a href="./audit" 
         class="inline-block bg-blue-600 text-white px-8 py-3 rounded-lg font-semibold hover:bg-blue-700">
        Start Free Audit →
      </a>
    </section>

  </main>
</Layout>
