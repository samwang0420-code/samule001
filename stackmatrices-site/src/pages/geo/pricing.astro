---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Pricing | GEO Marketing for Immigration Lawyers">
  <main class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    
    <!-- Header -->
    <div class="text-center mb-16">
      <nav class="text-sm text-slate-500 mb-8">
        <a href="/" class="hover:text-blue-600">Home</a>
        <span class="mx-2">/</span>
        <a href="./" class="hover:text-blue-600">GEO</a>
        <span class="mx-2">/</span>
        <span>Pricing</span>
      </nav>

      <h1 class="text-4xl font-bold text-slate-900 mb-4">
        Simple, Transparent Pricing
      </h1>
      <p class="text-xl text-slate-600 max-w-2xl mx-auto">
        Choose the plan that fits your practice. All plans include access to our GEO optimization platform.
      </p>
    </div>

    <!-- Pricing Cards -->
    <div class="grid md:grid-cols-3 gap-8 mb-16">
      
      <!-- Audit -->
      <div class="bg-white border border-slate-200 rounded-2xl p-8">
        <div class="text-sm font-semibold text-slate-500 uppercase mb-2">GEO Audit</div>
        <div class="flex items-baseline mb-4">
          <span class="text-4xl font-bold">$500</span>
          <span class="text-slate-500 ml-2">one-time</span>
        </div>
        <p class="text-slate-600 mb-6">
          Complete geographic precision analysis and optimization roadmap.
        </p>
        
        <ul class="space-y-3 mb-8">
          <li class="flex items-center">
            <span class="text-green-500 mr-2">✓</span>
            <span>Millimeter-level coordinate audit</span>
          </li>
          <li class="flex items-center">
            <span class="text-green-500 mr-2">✓</span>
            <span>Competitor analysis (20 firms)</span>
          </li>
          <li class="flex items-center">
            <span class="text-green-500 mr-2">✓</span>
            <span>Schema markup recommendations</span>
          </li>
          <li class="flex items-center">
            <span class="text-green-500 mr-2">✓</span>
            <span>30-day improvement checklist</span>
          </li>
          <li class="flex items-center">
            <span class="text-green-500 mr-2">✓</span>
            <span>PDF report + video walkthrough</span>
          </li>
        </ul>
        
        <a 
          href="mailto:geo@stackmatrices.com?subject=GEO Audit Inquiry" 
          class="block w-full text-center border-2 border-blue-600 text-blue-600 py-3 rounded-lg font-semibold hover:bg-blue-50"
        >
          Get Started
        </a>
      </div>

      <!-- Setup (Popular) -->
      <div class="bg-blue-600 text-white rounded-2xl p-8 relative">
        <div class="absolute top-0 right-0 bg-yellow-400 text-yellow-900 text-xs font-bold px-3 py-1 rounded-bl-lg rounded-tr-lg">
          MOST POPULAR
        </div>
        
        <div class="text-sm font-semibold text-blue-200 uppercase mb-2">GEO Setup</div>
        
        <div class="flex items-baseline mb-4">
          <span class="text-4xl font-bold">$2,000</span>
          <span class="text-blue-200 ml-2">one-time</span>
        </div>
        
        <p class="text-blue-100 mb-6">
          Complete implementation. We handle everything. You see results.
        </p>
        
        <ul class="space-y-3 mb-8">
          <li class="flex items-center">
            <span class="text-yellow-400 mr-2">✓</span>
            <span>Everything in Audit, plus:</span>
          </li>
          <li class="flex items-center">
            <span class="text-yellow-400 mr-2">✓</span>
            <span>Schema markup deployment</span>
          </li>
          <li class="flex items-center">
            <span class="text-yellow-400 mr-2">✓</span>
            <span>Google Business Profile optimization</span>
          </li>
          <li class="flex items-center">
            <span class="text-yellow-400 mr-2">✓</span>
            <span>Location page creation</span>
          </li>
          <li class="flex items-center">
            <span class="text-yellow-400 mr-2">✓</span>
            <span>Citation cleanup & building</span>
          </li>
          <li class="flex items-center">
            <span class="text-yellow-400 mr-2">✓</span>
            <span>3 months monitoring dashboard</span>
          </li>
          <li class="flex items-center">
            <span class="text-yellow-400 mr-2">✓</span>
            <span>Monthly strategy calls</span>
          </li>
        </ul>
        
        <a 
          href="mailto:geo@stackmatrices.com?subject=GEO Setup Inquiry" 
          class="block w-full text-center bg-white text-blue-600 py-3 rounded-lg font-semibold hover:bg-blue-50"
        >
          Get Started
        </a>
      </div>

      <!-- Retainer -->
      <div class="bg-white border border-slate-200 rounded-2xl p-8">
        <div class="text-sm font-semibold text-slate-500 uppercase mb-2">GEO Retainer</div>
        
        <div class="flex items-baseline mb-4">
          <span class="text-4xl font-bold">$500</span>
          <span class="text-slate-500 ml-2">/month</span>
        </div>
        
        <p class="text-slate-600 mb-6">
          Ongoing optimization and monitoring. Stay ahead of competitors.
        </p>
        
        <ul class="space-y-3 mb-8">
          <li class="flex items-center">
            <span class="text-green-500 mr-2">✓</span>
            <span>Everything in Setup, plus:</span>
          </li>
          <li class="flex items-center">
            <span class="text-green-500 mr-2">✓</span>
            <span>Real-time rank tracking</span>
          </li>
          <li class="flex items-center">
            <span class="text-green-500 mr-2">✓</span>
            <span>Competitor monitoring alerts</span>
          </li>
          <li class="flex items-center">
            <span class="text-green-500 mr-2">✓</span>
            <span>Schema dynamic updates</span>
          </li>
          <li class="flex items-center">
            <span class="text-green-500 mr-2">✓</span>
            <span>Monthly performance reports</span>
          </li>
          <li class="flex items-center">
            <span class="text-green-500 mr-2">✓</span>
            <span>Priority algorithm update response</span>
          </li>
        </ul>
        
        <a 
          href="mailto:geo@stackmatrices.com?subject=GEO Retainer Inquiry" 
          class="block w-full text-center border-2 border-blue-600 text-blue-600 py-3 rounded-lg font-semibold hover:bg-blue-50"
        >
          Get Started
        </a>
      </div>
    </div>

    <!-- FAQ -->
    <div class="max-w-3xl mx-auto">
      <h2 class="text-2xl font-bold text-center mb-8">Frequently Asked Questions</h2>
      
      <div class="space-y-6">
        <div class="border-b border-slate-200 pb-6">
          <h3 class="font-semibold mb-2">How long until I see results?</h3>
          <p class="text-slate-600">Most clients see ranking improvements within 30-45 days. Full results typically take 60-90 days depending on competition level.</p>
        </div>

        <div class="border-b border-slate-200 pb-6">
          <h3 class="font-semibold mb-2">Do you guarantee rankings?</h3>
          <p class="text-slate-600">No one can guarantee Google rankings. What we guarantee: implementation of industry-leading GEO practices, transparent reporting, and continuous optimization based on data.</p>
        </div>

        <div class="border-b border-slate-200 pb-6">
          <h3 class="font-semibold mb-2">What makes GEO different from regular SEO?</h3>
          <p class="text-slate-600">GEO focuses specifically on geographic precision: entrance-level coordinates, parking/transit data, local context integration, and dynamic Schema markup. For local service businesses like law firms, this often matters more than traditional backlinks.</p>
        </div>

        <div class="border-b border-slate-200 pb-6">
          <h3 class="font-semibold mb-2">Can I switch plans later?</h3>
          <p class="text-slate-600">Absolutely. Many clients start with the Audit, upgrade to Setup, then move to Retainer for ongoing optimization.</p>
        </div>

        <div>
          <h3 class="font-semibold mb-2">Do you work with non-immigration law firms?</h3>
          <p class="text-slate-600">Currently we specialize in immigration law because it's our area of expertise. We may expand to other practice areas in the future.</p>
        </div>
      </div>
    </div>

    <!-- CTA -->
    <div class="text-center mt-16 bg-slate-50 rounded-2xl p-12">
      <h2 class="text-2xl font-bold mb-4">Not sure which plan is right?</h2>
      <p class="text-slate-600 mb-6">
        Start with a free GEO score audit. See where you stand before deciding.
      </p>
      <a 
        href="./audit" 
        class="inline-block bg-blue-600 text-white px-8 py-3 rounded-lg font-semibold hover:bg-blue-700"
      >
        Get Free GEO Score →
      </a>
    </div>
  </main>
</Layout>
