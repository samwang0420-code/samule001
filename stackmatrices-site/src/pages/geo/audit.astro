---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Free GEO Audit | StackMatrices">
  <main class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    
    <!-- Breadcrumb -->
    <nav class="text-sm text-slate-500 mb-8">
      <a href="/" class="hover:text-blue-600">Home</a>
      <span class="mx-2">/</span>
      <a href="./" class="hover:text-blue-600">GEO</a>
      <span class="mx-2">/</span>
      <span>Audit</span>
    </nav>

    <!-- Header -->
    <div class="text-center mb-12">
      <h1 class="text-4xl font-bold text-slate-900 mb-4">
        Immigration Lawyer GEO Score
      </h1>
      <p class="text-lg text-slate-600">
        Check your geographic precision vs Houston competitors. Free.
      </p>
    </div>

    <!-- Form -->
    <div class="bg-white border border-slate-200 rounded-2xl p-8 shadow-sm mb-8">
      <form id="geoAuditForm" class="space-y-6">
        <div>
          <label class="block text-sm font-medium text-slate-700 mb-2">
            Law Firm Name
          </label>
          <input 
            type="text" 
            name="firmName"
            placeholder="e.g., Garcia Immigration Law"
            required
            class="w-full px-4 py-3 border border-slate-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500"
          />
        </div>

        <div>
          <label class="block text-sm font-medium text-slate-700 mb-2">
            Office Address
          </label>
          <input 
            type="text" 
            name="address"
            placeholder="e.g., 1234 Main Street, Houston, TX 77002"
            required
            class="w-full px-4 py-3 border border-slate-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500"
          />
        </div>

        <div class="grid md:grid-cols-2 gap-6">
          <div>
            <label class="block text-sm font-medium text-slate-700 mb-2">
              Your Email
            </label>
            <input 
              type="email" 
              name="email"
              placeholder="you@lawfirm.com"
              required
              class="w-full px-4 py-3 border border-slate-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500"
            />
            <p class="text-xs text-slate-500 mt-1">We'll send your full report here</p>
          </div>

          <div>
            <label class="block text-sm font-medium text-slate-700 mb-2">
              Primary Practice Area
            </label>
            <select 
              name="practiceArea"
              class="w-full px-4 py-3 border border-slate-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500"
            >
              <option>Green Card / Permanent Residence</option>
              <option>Citizenship / Naturalization</option>
              <option>Deportation Defense</option>
              <option>Work Visas (H1B, L1, etc.)</option>
              <option>Family Immigration</option>
              <option>Asylum / Refugee</option>
              <option>Business Immigration</option>
            </select>
          </div>
        </div>

        <button 
          type="submit"
          id="submitBtn"
          class="w-full bg-blue-600 text-white py-4 rounded-lg font-semibold text-lg hover:bg-blue-700 transition-colors"
        >
          Generate My GEO Score
        </button>
      </form>
    </div>

    <!-- Loading State -->
    <div id="loadingState" class="hidden text-center py-12">
      <div class="animate-spin rounded-full h-12 w-12 border-b-2 border-blue-600 mx-auto mb-4"></div>
      <p class="text-slate-600">Analyzing your geographic precision...</p>
      <p class="text-sm text-slate-400 mt-2">This takes 30-60 seconds</p>
    </div>

    <!-- Results State -->
    <div id="resultsState" class="hidden space-y-6">
      
      <!-- Score Card -->
      <div class="bg-white border border-slate-200 rounded-2xl p-8 shadow-sm">
        <div class="text-center mb-6">
          <p class="text-sm text-slate-500 mb-2">Your GEO Score</p>
          <div class="text-6xl font-bold text-blue-600" id="geoScore">72</div>
          <div class="text-slate-600 mt-2">out of 100</div>
        </div>

        <div class="grid grid-cols-3 gap-4 text-center">
          <div class="bg-slate-50 rounded-lg p-4">
            <div class="text-2xl font-bold text-slate-900" id="rankPosition">#14</div>
            <div class="text-xs text-slate-500">Current Rank</div>
          </div>
          <div class="bg-slate-50 rounded-lg p-4">
            <div class="text-2xl font-bold text-slate-900" id="competitorCount">127</div>
            <div class="text-xs text-slate-500">Competitors</div>
          </div>
          <div class="bg-slate-50 rounded-lg p-4">
            <div class="text-2xl font-bold text-green-600" id="potentialRank">#5</div>
            <div class="text-xs text-slate-500">Potential Rank</div>
          </div>
        </div>
      </div>

      <!-- Breakdown -->
      <div class="bg-white border border-slate-200 rounded-2xl p-8 shadow-sm">
        <h3 class="font-semibold text-lg mb-6">Score Breakdown</h3>
        
        <div class="space-y-4">
          <div>
            <div class="flex justify-between mb-1">
              <span>Coordinate Precision</span>
              <span class="font-semibold" id="coordScore">18/25</span>
            </div>
            <div class="w-full bg-slate-200 rounded-full h-2">
              <div class="bg-blue-600 h-2 rounded-full" style="width: 72%"></div>
            </div>
          </div>

          <div>
            <div class="flex justify-between mb-1">
              <span>Parking & Accessibility</span>
              <span class="font-semibold" id="parkingScore">8/25</span>
            </div>
            <div class="w-full bg-slate-200 rounded-full h-2">
              <div class="bg-yellow-500 h-2 rounded-full" style="width: 32%"></div>
            </div>
          </div>

          <div>
            <div class="flex justify-between mb-1">
              <span>Schema Markup</span>
              <span class="font-semibold" id="schemaScore">22/30</span>
            </div>
            <div class="w-full bg-slate-200 rounded-full h-2">
              <div class="bg-blue-600 h-2 rounded-full" style="width: 73%"></div>
            </div>
          </div>

          <div>
            <div class="flex justify-between mb-1">
              <span>Local Context (POIs)</span>
              <span class="font-semibold" id="poiScore">15/20</span>
            </div>
            <div class="w-full bg-slate-200 rounded-full h-2">
              <div class="bg-blue-600 h-2 rounded-full" style="width: 75%"></div>
            </div>
          </div>
        </div>
      </div>

      <!-- Recommendations -->
      <div class="bg-blue-50 border border-blue-200 rounded-2xl p-8">
        <h3 class="font-semibold text-lg mb-4 text-blue-900">Top 3 Actions to Improve</h3>
        
        <ol class="space-y-3 text-blue-800">
          <li>
            <strong>Add parking information</strong> to your Google Business Profile. Include nearest public lot and street parking options.
          </li>
          <li>
            <strong>Update Schema markup</strong> with Attorney + LegalService types. Add aggregateRating if you have 10+ reviews.
          </li>
          <li>
            <strong>Connect to nearby landmarks</strong> in your content ("5 minutes from Houston Immigration Court").
          </li>
        </ol>
      </div>

      <!-- CTA -->
      <div class="text-center bg-slate-900 rounded-2xl p-8 text-white">
        <h3 class="text-xl font-semibold mb-2">Want the Full Report?</h3>
        <p class="text-slate-400 mb-6">
          Detailed competitor analysis, actionable checklist, and 30-day improvement plan.
        </p>
        
        <a 
          href="./pricing" 
          class="inline-block bg-blue-600 text-white px-8 py-3 rounded-lg font-semibold hover:bg-blue-700"
        >
          View Pricing →
        </a>
      </div>
    </div>

  </main>

  <script>
    document.getElementById('geoAuditForm').addEventListener('submit', async (e) => {
      e.preventDefault();
      
      // Show loading
      document.getElementById('geoAuditForm').classList.add('hidden');
      document.getElementById('loadingState').classList.remove('hidden');
      
      // Simulate API call (replace with real Apify integration)
      await new Promise(r => setTimeout(r, 3000));
      
      // Show results
      document.getElementById('loadingState').classList.add('hidden');
      document.getElementById('resultsState').classList.remove('hidden');
      
      // TODO: Real implementation:
      // 1. Call Apify to scrape GMB data
      // 2. Calculate GEO score
      // 3. Store in Supabase
      // 4. Send email with full report
    });
  </script>
</Layout>
